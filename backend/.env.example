# The Essence - Journal & Publications Management System
# Environment Variables Configuration
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME="The Essence - Journal & Publications Management System"
APP_VERSION="1.0.0"
DEBUG=False

# Database Configuration
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/essence_journal

# Security Settings
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage Configuration
STORAGE_PATH=./storage
MANUSCRIPTS_PATH=./storage/manuscripts
REVIEWS_PATH=./storage/reviews
PUBLISHED_PATH=./storage/published
CERTIFICATES_PATH=./storage/certificates

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_MIME_TYPES=["application/pdf"]

# CORS Settings
# Add your frontend URL(s) here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "https://your-frontend-domain.vercel.app"]
